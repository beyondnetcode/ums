{
  "$schema": "https://opencode.ai/config.json",

  "share": "disabled",

  "model": "groq/qwen/qwen3-32b",
  "small_model": "groq/llama-3.1-8b-instant",

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  },

  "permission": {
    "edit": "ask",
    "bash": "ask"
  },

  "tools": {
    "write": true,
    "edit": true,
    "bash": true
  },

  "snapshot": true,

  "autoupdate": "notify",

  "attachment": {
    "image": {
      "auto_resize": true,
      "max_width": 1024,
      "max_height": 1024,
      "max_base64_bytes": 2097152
    }
  },

  "agent": {

    "bmad-architect": {
      "mode": "primary",
      "model": "groq/openai/gpt-oss-120b",
      "description": "BMAD Architect — ADRs, system design, debugging complejo, análisis multiarchivo. Stack: .NET 10 + React 18 + PostgreSQL 16. Lee .bmad-core/rules/global-rules.md antes de ejecutar."
    },

    "bmad-developer": {
      "mode": "primary",
      "model": "groq/qwen/qwen3-32b",
      "description": "BMAD Developer — implementación de stories, refactors, coding diario, tests. Nx monorepo en src/. NUNCA eliminar tests para hacer pasar un fix."
    },

    "bmad-analyst": {
      "mode": "primary",
      "model": "groq/openai/gpt-oss-20b",
      "description": "BMAD Analyst/PO — PRDs, historias, specs. Documentación bilingüe ES+EN obligatoria (R-01)."
    },

    "bmad-qa": {
      "mode": "subagent",
      "model": "groq/llama-3.1-8b-instant",
      "description": "BMAD QA/SM — criterios de aceptación, checklists, validaciones. Rápido y barato (560 T/s)."
    }

  },

  "provider": {
    "groq": {
      "models": {
        "qwen/qwen3-32b": {
          "name": "Qwen3 32B [developer]"
        },
        "llama-3.1-8b-instant": {
          "name": "Llama 3.1 8B [QA — 560 T/s]"
        },
        "llama-3.3-70b-versatile": {
          "name": "Llama 3.3 70B [versatile]"
        },
        "openai/gpt-oss-120b": {
          "name": "GPT-OSS 120B [architect]"
        },
        "openai/gpt-oss-20b": {
          "name": "GPT-OSS 20B [analyst]"
        },
        "groq/compound": {
          "name": "Groq Compound [agente web+code]"
        },
        "meta-llama/llama-4-scout-17b-16e-instruct": {
          "name": "Llama 4 Scout 17B"
        }
      }
    }
  },

  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".next/**",
      "coverage/**",
      "*.lock",
      "*.log",
      "tmp/**",
      ".cache/**",
      "vendor/**",
      "out/**",
      "*.map",
      ".env*",
      "src/.workspace/**"
    ]
  }
}
