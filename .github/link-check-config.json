{
  "ignorePatterns": [
    {
      "pattern": ".*"
    }
  ],
  "retryAttempts": 3,
  "retryDelay": 2000,
  "aliveStatusCodes": [200, 201, 202, 203, 204, 205, 206, 207, 208, 226, 301, 302, 303, 304, 305, 306, 307, 308],
  "httpHeaders": [
    {
      "urls": ["https://github.com/**", "https://raw.githubusercontent.com/**"],
      "headers": {
        "Accept": "text/html"
      }
    }
  ]
}