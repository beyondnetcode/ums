{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": [],
  "workspaceLayout": {
    "appsDir": "../apps",
    "libsDir": "../libs"
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "cache": true
    },
    "lint": {
      "cache": true
    }
  },
  "release": {
    "projects": [
      "*"
    ],
    "changelog": {
      "workspaceChangelog": {
        "createRelease": "github"
      }
    },
    "version": {
      "conventionalCommits": true
    }
  },
  "analytics": false
}