    "@types/node": "22.19.20",
    "@nestjs/common": "11.1.24",
    "@nestjs/core": "11.1.24",
    "@nestjs/testing": "11.1.24",
    "@nestjs/platform-express": "11.1.24",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "supertest": "7.2.2",
    "@types/supertest": "6.0.3",
    "@ums/sdk-contracts": "file:../typescript/sdk-contracts",
    "@ums/sdk-authorization": "file:../typescript/sdk-authorization",
    "@ums/sdk-testing": "file:../typescript/sdk-testing"
