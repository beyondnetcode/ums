{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": "",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Persistence": {
    "Provider": "SqlServer",
    "AggregateStoreMode": "InMemory",
    "UseSqlServerIdentityStores": false,
    "UseSqlServerAuthorizationStores": false,
    "SeedDevData": false,
    "EnableOutbox": true,
    "InitializePlatformStoreOnStartup": false
  },
  "Secrets": {
    "Source": "AppSettings",
    "KeyVault": {
      "Url": "https://your-vault-name.vault.azure.net/",
      "UseManagedIdentity": true
    }
  },
  "ApiSettings": {
    "RateLimiting": {
      "PermitLimit": 100,
      "WindowMinutes": 1
    },
    "MaxRequestBodySize": 10485760,
    "EnableSwagger": false
  }
}
