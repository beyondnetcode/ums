{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": "",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=UmsDev;User Id=sa;Password=Your_password123;TrustServerCertificate=True;Encrypt=False;"
  },
  "Persistence": {
    "Provider": "SqlServer",
    "AggregateStoreMode": "InMemory",
    "UseSqlServerIdentityStores": false,
    "UseSqlServerAuthorizationStores": false,
    "SeedDevData": true,
    "EnableOutbox": true,
    "InitializePlatformStoreOnStartup": false
  },
  "Secrets": {
    "Source": "AppSettings",
    "KeyVault": {
      "Url": "",
      "UseManagedIdentity": false
    }
  },
  "ApiSettings": {
    "RateLimiting": {
      "PermitLimit": 100,
      "WindowMinutes": 1
    },
    "MaxRequestBodySize": 10485760,
    "EnableSwagger": false
  }
}
