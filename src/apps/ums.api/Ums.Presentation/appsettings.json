{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": "",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Secrets": {
    "Source": "AppSettings",
    "KeyVault": {
      "Url": "",
      "UseManagedIdentity": false
    }
  },
  "ApiSettings": {
    "RateLimiting": {
      "PermitLimit": 100,
      "WindowMinutes": 1
    },
    "MaxRequestBodySize": 10485760,
    "EnableSwagger": false
  }
}
