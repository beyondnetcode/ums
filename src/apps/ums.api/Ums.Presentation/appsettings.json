{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": "",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=UmsDev;User Id=sa;Password=REPLACE_WITH_YOUR_PASSWORD;TrustServerCertificate=True;Encrypt=False;"
  },
  "Persistence": {
    "Provider": "SqlServer",
    "AggregateStoreMode": "InMemory",
    "UseSqlServerIdentityStores": false,
    "UseSqlServerAuthorizationStores": false,
    "UseSqlServerConfigurationStores": true,
    "SeedDevData": true,
    "EnableOutbox": true,
    "InitializePlatformStoreOnStartup": false
  },
  "Secrets": {
    "Source": "AppSettings",
    "KeyVault": {
      "Url": "",
      "UseManagedIdentity": false
    }
  },
  "ApiSettings": {
    "RateLimiting": {
      "PermitLimit": 100,
      "WindowMinutes": 1
    },
    "MaxRequestBodySize": 10485760,
    "EnableSwagger": false
  },
  "Observability": {
    "Logging": {
      "MinimumLevel": "Information",
      "ConsoleFormat": "CompactJson",
      "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {SessionTrackingId} {SourceContext} {Message:lj}{NewLine}{Exception}"
    },
    "Tracing": {
      "OtlpEndpoint": "",
      "ServiceVersion": "1.0.0"
    }
  }
}
