{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedOrigins": "http://localhost:5173,http://localhost:3000",
  "Secrets": {
    "Source": "AppSettings"
  },
  "ApiSettings": {
    "RateLimiting": {
      "PermitLimit": 1000,
      "WindowMinutes": 1
    },
    "EnableSwagger": true
  }
}
