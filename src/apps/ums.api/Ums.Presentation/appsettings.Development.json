{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedOrigins": "http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=UmsDev;Username=postgres;Password=root;",
    "RedisConnection": "localhost:6379"
  },
  "Persistence": {
    "Provider": "PostgreSql",
    "AggregateStoreMode": "PostgreSql",
    "UseSqlServerIdentityStores": false,
    "UseSqliteIdentityStores": false,
    "UsePostgreSqlIdentityStores": true,
    "UseSqlServerAuthorizationStores": false,
    "UseSqliteAuthorizationStores": false,
    "UsePostgreSqlAuthorizationStores": true,
    "UseSqlServerConfigurationStores": false,
    "UseSqliteConfigurationStores": false,
    "UsePostgreSqlConfigurationStores": true,
    "UseSqlServerApprovalsStores": false,
    "UseSqliteApprovalsStores": false,
    "UsePostgreSqlApprovalsStores": true,
    "UseSqlServerIgaStores": false,
    "UseSqliteIgaStores": false,
    "UsePostgreSqlIgaStores": true,
    "SeedDevData": true,
    "EnableOutbox": true,
    "InitializePlatformStoreOnStartup": true
  },
  "Secrets": {
    "Source": "AppSettings"
  },
  "ApiSettings": {
    "RateLimiting": {
      "PermitLimit": 1000,
      "WindowMinutes": 1
    },
    "EnableSwagger": true
  },
  "Jwt": {
    "Secret": "YOUR_DEVELOPMENT_JWT_SECRET_KEY_CHANGE_IN_LOCAL_ENV_MIN_32_CHARS",
    "Issuer": "ums-api",
    "Audience": "ums-web-app",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Observability": {
    "Logging": {
      "MinimumLevel": "Debug",
      "ConsoleFormat": "Text",
      "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {SessionTrackingId} {ErrorId} {SourceContext} {Message:lj}{NewLine}{Exception}",
      "LokiEndpoint": "",
      "LokiAppLabel": "ums-api",
      "LokiEnvLabel": "development"
    },
    "Tracing": {
      "OtlpEndpoint": "",
      "ServiceVersion": "1.0.0-dev"
    }
  }
}
