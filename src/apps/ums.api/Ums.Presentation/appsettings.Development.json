{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedOrigins": "http://localhost:5173,http://localhost:3000",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=UmsDev;User Id=sa;Password=Your_password123;TrustServerCertificate=True;Encrypt=False;"
  },
  "Persistence": {
    "Provider": "InMemory",
    "AggregateStoreMode": "InMemory",
    "UseSqlServerIdentityStores": false,
    "UseSqlServerAuthorizationStores": false,
    "UseSqlServerConfigurationStores": false,
    "SeedDevData": true,
    "EnableOutbox": false,
    "InitializePlatformStoreOnStartup": false
  },
  "Secrets": {
    "Source": "AppSettings"
  },
  "ApiSettings": {
    "RateLimiting": {
      "PermitLimit": 1000,
      "WindowMinutes": 1
    },
    "EnableSwagger": true
  }
}
