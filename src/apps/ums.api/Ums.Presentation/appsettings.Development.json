{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedOrigins": "http://localhost:5173,http://localhost:3000",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=UmsDev;Trusted_Connection=True;MultipleActiveResultSets=true;Encrypt=False;"
  },
  "Persistence": {
    "Provider": "InMemory",
    "AggregateStoreMode": "InMemory",
    "UseSqlServerIdentityStores": false,
    "UseSqlServerAuthorizationStores": false,
    "UseSqlServerConfigurationStores": false,
    "UseSqlServerApprovalsStores": false,
    "UseSqlServerIgaStores": false,
    "SeedDevData": true,
    "EnableOutbox": false,
    "InitializePlatformStoreOnStartup": false
  },
  "Secrets": {
    "Source": "UserSecrets"
  },
  "ApiSettings": {
    "RateLimiting": {
      "PermitLimit": 1000,
      "WindowMinutes": 1
    },
    "EnableSwagger": true
  },
  "Observability": {
    "Logging": {
      "MinimumLevel": "Debug",
      "ConsoleFormat": "Text",
      "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {SessionTrackingId} {SourceContext} {Message:lj}{NewLine}{Exception}"
    },
    "Tracing": {
      "OtlpEndpoint": "",
      "ServiceVersion": "1.0.0-dev"
    }
  }
}
