{
  "name": "app-api-dotnet",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet build Ums.sln",
        "cwd": "apps/ums.api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet test Ums.sln",
        "cwd": "apps/ums.api"
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet run --project Ums.Presentation",
        "cwd": "apps/ums.api"
      }
    }
  }
}
