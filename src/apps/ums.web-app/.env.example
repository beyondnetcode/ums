# UMS Web App — Environment Variables
# Copy this file to .env.local and fill in the values.

# Base path for REST API requests (relative to dev server for proxy)
VITE_API_BASE_PATH=/api/v1

# Base URL for the backend API (used by Vite dev proxy)
VITE_API_URL=https://localhost:7114

# GraphQL endpoint path (relative to dev server for proxy)
VITE_GRAPHQL_PATH=/graphql
