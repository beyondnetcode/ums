# =============================================================================
# UMS Web App — Environment Configuration
# =============================================================================

# =============================================================================
# DATA SOURCE MODE
# =============================================================================
# Choose one of three modes:
#
#   1. MOCK MODE (local without database):
#      VITE_USE_MOCKS=true
#      Uses hardcoded mock data in src/test/mocks/
#      No backend required - all data is fake
#
#   2. LOCAL DB MODE (SQLite local database):
#      VITE_USE_MOCKS=false
#      VITE_API_URL=http://localhost:7114 (or https://localhost:7114)
#      Uses the local API with SQLite database
#
#   3. PRODUCTION MODE (real database):
#      VITE_USE_MOCKS=false
#      VITE_API_URL=https://ums-api.your-domain.com
#      Uses the production API with production database

VITE_USE_MOCKS=false

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Base path for REST API requests (relative to dev server for proxy)
VITE_API_BASE_PATH=/api/v1

# Base URL for the backend API
VITE_API_URL=https://localhost:7114

# GraphQL endpoint path (relative to dev server for proxy)
VITE_GRAPHQL_PATH=/graphql